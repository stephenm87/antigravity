# ============================================================
#  Root Scripts — Environment Variables
#  Used by generate-*.js scripts for PDF generation
#  Copy this to .env and fill in real values.
#  NEVER commit .env — it is in .gitignore
# ============================================================

# --- AI APIs (for scripts that call Gemini, etc.) ---
GEMINI_API_KEY=your_gemini_key_here

# --- Puppeteer / Chrome path (for PDF export scripts) ---
# Usually auto-detected. Only set if chrome isn't found.
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
